{
	"name": "@syndie/n8n-nodes-syndie",
	"version": "0.1.1",
	"description": "n8n node for the Syndie API",
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@11.0.8",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"homepage": "https://syndie.io",
	"author": {
		"name": "Syndie",
		"email": "support@syndie.io"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Syndie-io/n8n-nodes-syndie"
	},
	"engines": {
		"node": ">=20.15"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"format": "prettier nodes credentials --write",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/SyndieOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Syndie/SyndieTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.35.0",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
